:"61","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"62","usedDeprecatedRules":"34"},{"filePath":"63","messages":"64","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"65","usedDeprecatedRules":"34"},{"filePath":"66","messages":"67","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"C:\\Users\\ikaco\\Desktop\\amazon-asus\\src\\index.js",[],["68","69"],"C:\\Users\\ikaco\\Desktop\\amazon-asus\\src\\reportWebVitals.js",[],"C:\\Users\\ikaco\\Desktop\\amazon-asus\\src\\App.js",["70","71"],"C:\\Users\\ikaco\\Desktop\\amazon-asus\\src\\stateMenagement\\reducer.js",[],"C:\\Users\\ikaco\\Desktop\\amazon-asus\\src\\stateMenagement\\StateProvider.js",[],"C:\\Users\\ikaco\\Desktop\\amazon-asus\\src\\pages\\home\\HomePage.jsx",[],"C:\\Users\\ikaco\\Desktop\\amazon-asus\\src\\firebase\\firebase.js",[],"C:\\Users\\ikaco\\Desktop\\amazon-asus\\src\\pages\\checkout\\CheckoutPage.jsx",["72"],"import React from \"react\";\r\nimport CheckoutProduct from \"../../components/checkoutProduct/checkoutProduct.component\";\r\nimport Subtotal from \"../../components/subtotal/subtotal.component\";\r\nimport { useStateValue } from \"../../stateMenagement/StateProvider\";\r\nimport \"./CheckoutPage.styles.css\";\r\n\r\nfunction CheckoutPage() {\r\n  const [{ basket, user }, dispatch] = useStateValue();\r\n\r\n  return (\r\n    <div className=\"checkout\">\r\n      <div className=\"checkout-left\">\r\n        <img\r\n          src=\"https://images-na.ssl-images-amazon.com/images/G/02/UK_CCMP/TM/OCC_Amazon1._CB423493668_.jpg\"\r\n          alt=\"\"\r\n          className=\"checkout-ad\"\r\n        />\r\n        <div>\r\n          <h3>Hello, {user ? user.email : \"Guest\"}</h3>\r\n          <h2 className=\"checkout-title\">Your shopping basket</h2>\r\n          {/* mapping through every single one item that is currently at the basket and need to show up in the checkout page  */}\r\n          {basket.map((x) => (\r\n            <CheckoutProduct\r\n              id={x.id}\r\n              title={x.title}\r\n              image={x.image}\r\n              price={x.price}\r\n              rating={x.rating}\r\n            />\r\n          ))}\r\n        </div>\r\n      </div>\r\n      <div className=\"checkout-right\">\r\n        <Subtotal />\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default CheckoutPage;\r\n","C:\\Users\\ikaco\\Desktop\\amazon-asus\\src\\pages\\login\\LoginPage.jsx",[],"C:\\Users\\ikaco\\Desktop\\amazon-asus\\src\\pages\\payment\\PaymentPage.jsx",["73","74"],"C:\\Users\\ikaco\\Desktop\\amazon-asus\\src\\components\\header\\header.component.jsx",["75"],"import React from \"react\";\r\nimport \"./header.styles.css\";\r\n\r\nimport SearchIcon from \"@material-ui/icons/Search\";\r\nimport ShoppingBasketIcon from \"@material-ui/icons/ShoppingBasket\";\r\nimport { Link } from \"react-router-dom\";\r\nimport { useStateValue } from \"../../stateMenagement/StateProvider\";\r\nimport { auth } from \"../../firebase/firebase\";\r\n\r\nfunction Header() {\r\n  // we currently need only the basket and the user of the whole CURRENT STATE, that's why we destructure only those two in the [] below this line\r\n  const [{ basket, user }, dispatch] = useStateValue();\r\n  const handleAuthentication = () => {\r\n    if (user) {\r\n      auth.signOut();\r\n    } else {\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"header\">\r\n      <Link to=\"/\">\r\n        <img\r\n          className=\"header-logo\"\r\n          src=\"http://pngimg.com/uploads/amazon/amazon_PNG11.png\"\r\n          alt=\"amazon-logo\"\r\n        />\r\n      </Link>\r\n      <div className=\"header-search\">\r\n        <input className=\"header-search-input\" />\r\n        <SearchIcon className=\"header-search-icon\" />\r\n      </div>\r\n      <div className=\"header-nav\">\r\n        <Link to={!user ? \"/login\" : \"/\"}>\r\n          <div onClick={handleAuthentication} className=\"header-option\">\r\n            <span className=\"header-option-line-one\">\r\n              Hello {user ? user?.email : \"Guest\"}\r\n            </span>\r\n            <span className=\"header-option-line-two\">\r\n              {!user ? \"Sign In\" : \"Sign Out\"}\r\n            </span>\r\n          </div>\r\n        </Link>\r\n        <div className=\"header-option\">\r\n          <span className=\"header-option-line-one\">Returns</span>\r\n          <span className=\"header-option-line-two\">& Orders</span>\r\n        </div>\r\n        <div className=\"header-option\">\r\n          <span className=\"header-option-line-one\">Your</span>\r\n          <span className=\"header-option-line-two\">Prime</span>\r\n        </div>\r\n        <Link to=\"/checkout\">\r\n          <div className=\"header-option-basket\">\r\n            <ShoppingBasketIcon />\r\n            <span className=\"header-option-line-two header-basket-count\">\r\n              {/* set the length of the current state of the basket. import it first\r\n              on top of the scope */}\r\n              {basket.length}\r\n            </span>\r\n          </div>\r\n        </Link>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default Header;\r\n","C:\\Users\\ikaco\\Desktop\\amazon-asus\\src\\components\\product\\product.component.jsx",["76"],"import React from \"react\";\r\nimport { useStateValue } from \"../../stateMenagement/StateProvider\";\r\nimport \"./product.styles.css\";\r\n\r\nfunction Product({ id, title, image, price, rating }) {\r\n  const [{ basket }, dispatch] = useStateValue();\r\n\r\n  // console.log(\"this is the basket --> \", basket);\r\n\r\n  const addToBasketDispatchAction = () => {\r\n    //dispatch the item into the data layer\r\n\r\n    dispatch({\r\n      type: \"ADD_TO_BASKET\",\r\n      item: {\r\n        id,\r\n        title,\r\n        image,\r\n        price,\r\n        rating,\r\n      },\r\n    });\r\n  };\r\n\r\n  return (\r\n    <div className=\"product\">\r\n      <div className=\"product-info\">\r\n        <p>{title}</p>\r\n        <p className=\"product-price\">\r\n          <strong>{price + \" \"}</strong>\r\n          <small>\r\n            <strong>€</strong>\r\n          </small>\r\n        </p>\r\n        <div className=\"product-rating\">\r\n          {/* trick to fill up how many stars should display */}\r\n          {Array(rating)\r\n            .fill()\r\n            .map((_, i) => (\r\n              <p>⭐</p>\r\n            ))}\r\n        </div>\r\n      </div>\r\n      <img src={image} alt=\"\" />\r\n      <button onClick={addToBasketDispatchAction}>Add to Basket</button>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default Product;\r\n","C:\\Users\\ikaco\\Desktop\\amazon-asus\\src\\components\\checkoutProduct\\checkoutProduct.component.jsx",["77"],"import React from \"react\";\r\nimport { useStateValue } from \"../../stateMenagement/StateProvider\";\r\nimport \"./checkoutProduct.styles.css\";\r\n\r\nfunction CheckoutProduct({ id, image, title, price, rating }) {\r\n  const [{ basket }, dispatch] = useStateValue();\r\n\r\n  const removeFromBasketDispatchAction = () => {\r\n    //remove the item from the basket\r\n    dispatch({\r\n      type: \"REMOVE_FROM_BASKET\",\r\n      id: id,\r\n    });\r\n  };\r\n  return (\r\n    <div className=\"checkout-product\">\r\n      <img\r\n        className=\"checkout-product-image\"\r\n        src={image}\r\n        alt=\"checkout-product-img\"\r\n      />\r\n      <div className=\"checkout-product-info\">\r\n        <p className=\"checkout-product-title\">{title}</p>\r\n        <p className=\"checkout-product-price\">\r\n          <small>€</small>\r\n          <strong>{price}</strong>\r\n        </p>\r\n        <div className=\"checkout-product-rating\">\r\n          {Array(rating)\r\n            .fill()\r\n            .map((_, i) => (\r\n              <p>⭐</p>\r\n            ))}\r\n        </div>\r\n        <button onClick={removeFromBasketDispatchAction}>\r\n          Remove from basket\r\n        </button>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default CheckoutProduct;\r\n","C:\\Users\\ikaco\\Desktop\\amazon-asus\\src\\components\\subtotal\\subtotal.component.jsx",["78"],"import React from \"react\";\r\nimport \"./subtotal.styles.css\";\r\nimport CurrencyFormat from \"react-currency-format\";\r\nimport { useStateValue } from \"../../stateMenagement/StateProvider\";\r\nimport { totalPriceToPay } from \"../../stateMenagement/reducer\";\r\nimport { useHistory } from \"react-router-dom\";\r\n\r\nfunction Subtotal() {\r\n  const [{ basket }, dispatch] = useStateValue();\r\n  const history = useHistory();\r\n\r\n  return (\r\n    <div className=\"subtotal\">\r\n      <CurrencyFormat\r\n        renderText={(value) => (\r\n          <>\r\n            <p>\r\n              Subtotal ({basket.length} items): <strong>{value}</strong>\r\n            </p>\r\n            <small className=\"subtotal-gift\">\r\n              <input type=\"checkbox\" /> This order contains a gift\r\n            </small>\r\n          </>\r\n        )}\r\n        decimalScale={2}\r\n        value={totalPriceToPay(basket)} // to calculate the sum of every items * price for each one;\r\n        displayType={\"text\"}\r\n        thousandSeparator={true}\r\n        prefix={\"€\"}\r\n      />\r\n      <button onClick={(e) => history.push(\"/payment\")}>\r\n        Proceed to Checkout\r\n      </button>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default Subtotal;\r\n","C:\\Users\\ikaco\\Desktop\\amazon-asus\\src\\helpers\\axios.js",[],{"ruleId":"79","replacedBy":"80"},{"ruleId":"81","replacedBy":"82"},{"ruleId":"83","severity":1,"message":"84","line":24,"column":12,"nodeType":"85","messageId":"86","endLine":24,"endColumn":16},{"ruleId":"87","severity":1,"message":"88","line":47,"column":6,"nodeType":"89","endLine":47,"endColumn":8,"suggestions":"90"},{"ruleId":"83","severity":1,"message":"91","line":8,"column":28,"nodeType":"85","messageId"